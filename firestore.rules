rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isOwner(userId) || isAdmin();

      match /chatHistory/{messageId} {
        allow read, create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    match /reports/{reportId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() ||
        (isOwner(resource.data.userId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['evidenceUrls']));
      allow delete: if false;
    }

    match /callRequests/{callId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() ||
        (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /chatLogs/{logId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
