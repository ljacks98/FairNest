{
  "expo": {
    "name": "FairNest – Housing Support AI",
    "slug": "fairnest",
    "owner": "teroindian",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fairnest",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.fairnest.app" },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.fairnest.app"
    },
    "web": { "bundler": "metro" }
  }
}
